# Project URL — Dashboard → Settings → API → Project URL (NOT the REST endpoint)
# Correct:   https://vpvsfnqsdpxoegjajgik.supabase.co
# Incorrect: https://vpvsfnqsdpxoegjajgik.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_URL=https://vpvsfnqsdpxoegjajgik.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Local dev only — magic-link redirects use http://localhost:3000 in development.
# Production always uses https://grndn.app (localhost is never used in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
OPENAI_API_KEY=
# Server-only — never expose to the browser (billing webhooks, admin routes)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Waitlist (optional Resend notification) ────────────────────────────────────
# When set with RESEND_API_KEY, sends an email on each new waitlist signup
WAITLIST_NOTIFICATION_EMAIL=
RESEND_API_KEY=
# Optional sender — must be a verified domain in Resend (default: onboarding@resend.dev)
RESEND_FROM_EMAIL=grndnapp@gmail.com

# Dashboard → Authentication → Providers: enable Email (magic link and/or password)
# SQL: run supabase/migrations/20250509120000_onboarding_profiles.sql in the SQL Editor

# OpenAI (server only) — POST /api/workout-plan
# Optional override (default: gpt-4o-mini)
OPENAI_WORKOUT_MODEL=gpt-5.4-mini

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
# Beta deployment: keep ENABLE_PAYMENTS=false — all payment checks are bypassed.
ENABLE_PAYMENTS=false
SHOW_PRICING_PAGE=false
# Stripe test mode keys (see docs/STRIPE_SETUP.md)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Monthly ($9.99/mo) and quarterly ($25.99/3mo) price IDs from Stripe Dashboard → Products
STRIPE_PRICE_ID_MONTHLY=price_1TnHEARM2v6pIHpMH3DR1xBj
STRIPE_PRICE_ID_QUARTERLY=price_1TnHFBRM2v6pIHpM5dp2Ue2l
# Legacy fallback for monthly — use STRIPE_PRICE_ID_MONTHLY instead
STRIPE_PRICE_ID=

# Optional — protects POST /api/billing/grant-beta for admin beta grandfathering
BILLING_ADMIN_SECRET=
